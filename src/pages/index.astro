---
import BaseLayout from "../layouts/BaseLayout.astro";
import { pageContent, percorsi, programTracks, sectionAnchors } from "../data/percorsi";
---

<BaseLayout title="Percorsi Master | Beauty Line Academy" description={pageContent.hero.description}>
  <header class="site-header">
    <div class="container header-inner">
      <strong>{pageContent.brand}</strong>
      <nav class="header-nav">
        <a href={`#${sectionAnchors.percorsi}`}>Percorsi</a>
        <a href={`#${sectionAnchors.programma}`}>Programma</a>
        <a href={`#${sectionAnchors.requisiti}`}>Requisiti</a>
        <a href={`#${sectionAnchors.faq}`}>FAQ</a>
        <a href={`#${sectionAnchors.contatti}`}>Contatti</a>
      </nav>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="container hero-inner">
        <div>
          <p class="eyebrow">{pageContent.hero.eyebrow}</p>
          <h1>{pageContent.hero.title}</h1>
          <p class="marked-text">{pageContent.hero.depositLine}</p>
          <p>{pageContent.hero.description}</p>
          <p class="marked-strong">{pageContent.hero.limitedSeats}</p>
          <div class="btn-row">
            <a class="btn btn-primary" href={`#${sectionAnchors.contatti}`}>{pageContent.hero.ctaPrimary}</a>
            <a class="btn btn-secondary" href={`#${sectionAnchors.programma}`}>{pageContent.hero.ctaSecondary}</a>
          </div>
        </div>
        <div class="placeholder-media" role="img" aria-label={pageContent.hero.imageAlt}>
          {pageContent.hero.imagePlaceholder}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <article class="card content-card">
          {pageContent.hero.introParagraphs.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
          <p class="strong-black-line">{pageContent.hero.strongLine}</p>
          <p class="marked-text">{pageContent.hero.depositLine}</p>
        </article>
      </div>
    </section>

    <section class="section" id={sectionAnchors.percorsi}>
      <div class="container">
        <h2 class="section-title">{pageContent.comparisonTitle}</h2>
        <p class="section-subtitle">{pageContent.comparisonIntro}</p>
        <div class="grid two-col percorso-cards-grid" style="margin-top: 24px;">
          {percorsi.map((percorso) => (
            <article class="card content-card">
              <p class="percorso-name">{percorso.shortName}</p>
              <h4>Date percorso</h4>
              <ul class="date-master-list">
                {programTracks
                  .find((track) => track.name === percorso.name)
                  ?.sessions.map((session) => (
                    <li class="date-master-line">
                      <span class="date-master-date">{session.date}</span>
                      <span class="date-master-separator">-</span>
                      <span class="date-master-name">{session.master}</span>
                    </li>
                  ))}
              </ul>
            </article>
          ))}
        </div>
        <article class="card content-card shared-info-card" style="margin-top: 20px;">
          <h3>{pageContent.sharedInfoTitle}</h3>
          <div class="shared-feature-grid" style="margin-top: 14px;">
            {pageContent.sharedFeatures.map((feature) => (
              <p class="shared-feature-item">{feature}</p>
            ))}
          </div>
          <p class="shared-strong-line">{pageContent.sharedInfoStrong}</p>
          <p class="shared-ceremony">
            <strong>{pageContent.openingCeremonyLabel}:</strong> {pageContent.openingCeremonyDate}
          </p>
        </article>
      </div>
    </section>

    <section class="section" id={sectionAnchors.programma}>
      <div class="container">
        <h2 class="section-title">{pageContent.programSectionTitle}</h2>
        <p class="marked-text">{pageContent.hero.depositLine}</p>
        <p class="section-subtitle">{pageContent.programIntro}</p>
        {pageContent.programDetails.map((line) => (
          <p>{line}</p>
        ))}
        {programTracks.map((track) => (
          <div style="margin-top: 26px;">
            <p class="percorso-name percorso-name-program" style="margin-bottom: 0;">{track.name}</p>
            <p class="marked-text" style="text-align: center;">{track.description}</p>
            <p class="marked-text" style="text-align: center;">{track.description2}</p>
            <div class="grid three-col" style="margin-top: 10px;">
              {track.sessions.map((session) => (
                <article class="card schedule-card">
                  <img
                    src={session.image}
                    alt={`Master ${session.master}`}
                    loading="lazy"
                    style={session.imagePosition ? `object-position: ${session.imagePosition};` : undefined}
                  />
                  <div class="schedule-card-body">
                    <p class="eyebrow">{session.date}</p>
                    <h3>{session.master}</h3>
                    <p>{session.lessonPlaceholder}</p>
                  </div>
                </article>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    {percorsi.map((percorso) => (
      <section class="section">
        <div class="container">
          <p class="marked-text" style="text-align: center; margin-bottom: 20px;">Solo 12 posti disponibili per ogni percorso master</p>
          <div class="grid two-col">
            <article class="card content-card">
              <p class="percorso-name">{percorso.name}</p>
              <h2 class="section-title" style="font-size: clamp(1.4rem, 2.1vw, 2rem);">{percorso.subtitle}</h2>
              <p>{percorso.description}</p>
              <h4>Cosa include</h4>
              <ul>
                {percorso.highlights.map((highlight) => (
                  <li>{highlight}</li>
                ))}
              </ul>
            </article>
            <article class="card content-card">
              <h3>Certificazione finale</h3>
              <p class="section-subtitle">Durante il percorso ogni partecipante verrà valutata dai Master.</p>
              <p class="section-subtitle">Il punteggio finale determinerà il livello della certificazione ottenuta.</p>
              <ul style="margin-top: 12px;">
                {percorso.certifications.map((certification) => (
                  <li>
                    <span
                      class={`certification-level certification-${certification.level
                        .toLowerCase()
                        .replace(/\s+/g, "-")}`}
                    >
                      {certification.level}
                    </span>
                    {certification.label ? ` - ${certification.label}` : ""}
                  </li>
                ))}
              </ul>
              <div class="placeholder-media" style="margin-top: 18px; min-height: 160px;">
                Placeholder foto master / lavori corso
              </div>
            </article>
          </div>
        </div>
      </section>
    ))}

    <section class="section">
      <div class="container">
        <article class="card content-card" style="margin-bottom: 22px;">
          <p class="eyebrow">{pageContent.certificationSection.title}</p>
          <p>{pageContent.certificationSection.textA}</p>
          <p>{pageContent.certificationSection.textB}</p>
        </article>
        <article class="card content-card">
          <p class="eyebrow">MASTER AWARD DAY</p>
          <h2 class="section-title">{pageContent.masterAwardDay.title}</h2>
          <p><strong>{pageContent.masterAwardDay.date}</strong> - {pageContent.masterAwardDay.description}</p>
          <div style="margin-top: 12px;">
            {pageContent.masterAwardDay.bullets.map((item) => (
              <p>{item}</p>
            ))}
          </div>
        </article>
      </div>
    </section>

    <section class="section" id={sectionAnchors.requisiti}>
      <div class="container grid two-col">
        <article class="card content-card">
          <h2 class="section-title">Requisiti di partecipazione</h2>
          <p>{pageContent.requirementsIntro}</p>
          <p class="section-subtitle">Per partecipare è necessario aver completato almeno uno dei seguenti corsi:</p>
          <ul style="margin-top: 12px;">
            {pageContent.requirements.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
          <h3>{pageContent.requirementsEvaluationTitle}</h3>
          <p>{pageContent.requirementsEvaluation}</p>
          <h3>{pageContent.preMasterTitle}</h3>
          <p>{pageContent.preMaster}</p>
        </article>
        <article class="card content-card">
          <h2 class="section-title">{pageContent.materialsTitle}</h2>
          <p>{pageContent.materialsIntro}</p>
          <h3>{pageContent.materialsCarryTitle}</h3>
          <p class="section-subtitle">{pageContent.materialsCarryText}</p>
          <ul style="margin-top: 12px;">
            {pageContent.materials.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </article>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2 class="section-title">Cosa succede durante una giornata di master</h2>
        <div class="grid three-col" style="margin-top: 20px;">
          {pageContent.dayFlow.map((step) => (
            <article class="card content-card">
              <p>{step}</p>
            </article>
          ))}
        </div>
        <p style="margin-top: 16px;">{pageContent.dayFlowOutro}</p>
        <article class="card content-card" style="margin-top: 22px;">
          <h3>Perché partecipare ai Percorsi Master</h3>
          <p>{pageContent.whyParticipate}</p>
          <p><strong>{pageContent.urgency}</strong></p>
          <p class="marked-strong">{pageContent.closingStrong}</p>
        </article>
      </div>
    </section>

    <section class="section" id={sectionAnchors.faq}>
      <div class="container">
        <h2 class="section-title">Domande frequenti</h2>
        <div class="card content-card" style="margin-top: 16px;">
          {pageContent.faqs.map((faq) => (
            <details class="faq-item">
              <summary>{faq.question}</summary>
              <p>{faq.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="section" id={sectionAnchors.contatti}>
      <div class="container">
        <article class="card lead-wrap">
          <h2 class="section-title" style="margin-bottom: 10px;">{pageContent.leadForm.title}</h2>
          <p class="section-subtitle">{pageContent.leadForm.subtitle}</p>
          <p class="marked-strong">{pageContent.leadForm.limitedSeatsLine}</p>

          <form class="lead-form" action="#" method="post">
            <input name="nome" type="text" placeholder="Nome e cognome" />
            <input name="email" type="email" placeholder="Email" />
            <input name="telefono" type="tel" placeholder="Telefono" />
            <textarea name="messaggio" placeholder="Dimmi quale percorso ti interessa"></textarea>
            <label class="small-text">
              <input type="checkbox" name="privacy" />
              {pageContent.leadForm.privacyText}
            </label>
            <button type="submit" class="btn btn-primary">{pageContent.leadForm.submitLabel}</button>
          </form>
        </article>
      </div>
    </section>
  </main>

  <footer>
    <div class="container">
      <p><strong>{pageContent.brand}</strong></p>
      <p>{pageContent.contactAddress}</p>
      <p>Info e iscrizioni: {pageContent.contactPhone}</p>
      <p>
        Sito ufficiale: <a href={pageContent.siteUrl} target="_blank" rel="noreferrer">{pageContent.siteUrl}</a>
      </p>
    </div>
  </footer>

  <script is:inline>
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const revealTargets = Array.from(
      document.querySelectorAll("main section, main section article, footer .container > *"),
    );

    revealTargets.forEach((el) => el.classList.add("reveal"));

    if (reduceMotion) {
      revealTargets.forEach((el) => el.classList.add("is-visible"));
    } else {
      const observer = new IntersectionObserver(
        (entries, obs) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              obs.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15, rootMargin: "0px 0px -5% 0px" },
      );

      revealTargets.forEach((el) => observer.observe(el));
    }
  </script>
</BaseLayout>
